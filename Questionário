  main.appendChild(mh);

  main.appendChild(criarCard('ET0', 'Qual é a etapa desta entrevista?', true,
    criarRadio(scope, 'ET0_etapa', [
      {val:'1', label:'1 – Primeira entrevista'},
      {val:'2', label:'2 – Segunda entrevista'},
