  area.appendChild(criarCard('MEI1','Na semana de referência, estava cadastrado como Microempreendedor Individual?', true,
    criarRadio(meisc,'MEI1_cadastrado',[{val:'1',label:'Sim'},{val:'2',label:'Não'}], (v) => { const c2 = area.querySelector('#q_MEI2'); if (c2) mostrarOcultar(c2, v === '1'); })
  ));

  const cardMEI2 = criarCard('MEI2','Na semana de referência, trabalhou como Microempreendedor Individual (MEI)?', false,
