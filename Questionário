function aplicarSaltosHabitacao() {
  const scope = dadosGlobais.habitacao;
  const etapa = getVal(scope, 'ET0_etapa') || '1';

  const showQ8 = getVal(scope,'H7_agua') === '1';
  const nbh = parseInt(getVal(scope,'H11A_banheiros') || '0');
  const showQ12A = nbh > 0;
  const energ = getVal(scope,'H14_energia') || [];
  const showQ15 = energ.includes('rede');
  const comb = getVal(scope,'H16A_combustivel') || [];
  const showQ16B = comb.length >= 2;
  const cond = getVal(scope,'H17_condicao');
  const showQ18 = cond === '2';
  const showQ19 = cond === '3';
  const showQ20 = cond === '1' || cond === '2';
  const showQ20A = true;

  const todasAsDinamicas = {
    'q_H8': showQ8,
    'q_H12A': showQ12A,
    'q_H15': showQ15,
    'q_H16B': showQ16B,
    'q_H18': showQ18,
    'q_H19': showQ19,
    'q_H20': showQ20,
    'q_H20A': showQ20A
  };

  const isPrimeiraEtapa = (etapa === '1');
  const cardsPermitidosSeNaoPrimeira = ['q_ET0', 'q_H0', 'q_H0a', 'q_H0b', 'q_H0c', 'q_H17'];

  const todosCards = document.querySelectorAll('#main .questao-card');
  todosCards.forEach(card => {
     let deveMostrar = true;

     if (!isPrimeiraEtapa && !cardsPermitidosSeNaoPrimeira.includes(card.id)) {
        deveMostrar = false;
     }
     else if (todasAsDinamicas[card.id] !== undefined) {
        deveMostrar = todasAsDinamicas[card.id];
     }

     mostrarOcultar(card, deveMostrar);
  });
}

