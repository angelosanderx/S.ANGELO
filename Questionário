  divBlocoNAO_OCUP.appendChild(criarCard('T79', 'T79 – Quantas horas por semana poderia trabalhar?', false, (() => { const d=document.createElement('div'); d.appendChild(criarInput(tscope,'T79_horas_poderia','number','Ex: 40')); return d; })()));
  divBlocoNAO_OCUP.appendChild(criarCard('T80', 'T80 – Alguma vez na vida teve algum trabalho pelo qual ganhava dinheiro, produtos, mercadorias ou benefícios?', false, criarRadio(tscope, 'T80_algum_trab', [{val:'1',label:'Sim'},{val:'2',label:'Não'}], () => aplicarSaltosTrabalho(tscope, area))));
  divBlocoNAO_OCUP.appendChild(criarCard('T81', 'T81 – Alguma vez na vida ajudou sem receber pagamento no trabalho remunerado de algum membro do domicílio ou parente?', false, criarRadio(tscope, 'T81_ajudou', [{val:'1',label:'Sim'},{val:'2',label:'Não'}], () => aplicarSaltosTrabalho(tscope, area))));
  divBlocoNAO_OCUP.appendChild(criarCard('T82', 'T82 – No período de captação de 358 dias, trabalhou por pelo menos 1 hora?', false, criarRadio(tscope, 'T82_trab_ano', [{val:'1',label:'Sim'},{val:'2',label:'Não'}], () => aplicarSaltosTrabalho(tscope, area))));
  divBlocoNAO_OCUP.appendChild(criarCard('T82a', 'T82a – No período de três meses trabalhou por pelo menos uma hora?', false, criarRadio(tscope, 'T82a_trab_3m', [{val:'1',label:'Sim'},{val:'2',label:'Não'}], () => aplicarSaltosTrabalho(tscope, area))));
  divBlocoNAO_OCUP.appendChild(criarCard('T94a', 'T94a – Por que motivo saiu desse último trabalho?', false, criarRadio(tscope, 'T94a_motivo_saiu', [{val:'1',label:'Pediu para sair'},{val:'2',label:'Foi dispensado pelo empregador'},{val:'3',label:'Aposentou-se'},{val:'4',label:'O negócio fechou'},{val:'5',label:'Fim de contrato temporário'},{val:'6',label:'Problema de saúde, gestação ou acidente'},{val:'7',label:'Falta de procura ou clientes'},{val:'8',label:'Outro motivo'}])));

  area.appendChild(divBlocoNAO_OCUP);

  const badgeFim = document.createElement('div'); badgeFim.className='badge-modulo'; badgeFim.textContent='ENCERRAMENTO – TODOS OS MORADORES';
  area.appendChild(badgeFim);

  area.appendChild(criarCard('T97',
    'T97 – Na semana de referência era associado(a) a algum sindicato ou associação de trabalhadores?', true,
    criarRadio(tscope,'T97_sindicato',[{val:'1',label:'Sim'},{val:'2',label:'Não'}])
  ));

  area.appendChild(criarCard('T98',
    'T98 – Com que idade começou a trabalhar pela primeira vez?', true,
    (() => { const d=document.createElement('div'); d.appendChild(criarInput(tscope,'T98_idade_trabalho','number','Ex: 18')); return d; })()
  ));

  area.appendChild(criarCardInformante(tscope, 'T130', 'Quem prestou as informações sobre trabalho?', [
    {val:'1',label:'A própria pessoa'},{val:'2',label:'Outro morador'},{val:'3',label:'Pessoa não moradora'}
  ]));

