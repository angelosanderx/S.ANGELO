function estaOcupado(scope) {
  return getVal(scope,'T1_trab_rem') === '1' || getVal(scope,'T2_produtos') === '1' || getVal(scope,'T3_bico') === '1' || getVal(scope,'T4_ajuda') === '1' || getVal(scope,'T5_afastado') === '1';
}

function aplicarSaltosTrabalho(scope, area) {
  if (!area) return;
  const set = (id, vis) => { const el = area.querySelector('#q_' + id); if (el) mostrarOcultar(el, vis); };
  const setDiv = (id, vis) => { const el = document.getElementById(id); if (el) mostrarOcultar(el, vis); };

  const t1 = getVal(scope,'T1_trab_rem');
  const t2 = getVal(scope,'T2_produtos');
  const t3 = getVal(scope,'T3_bico');
  const t4 = getVal(scope,'T4_ajuda');
  const t5 = getVal(scope,'T5_afastado');

  set('T2', t1 === '2');
  set('T3', t1 === '2' && t2 === '2');
  set('T4', t1 === '2' && t2 === '2' && t3 === '2');
  set('T5', t1 === '2' && t2 === '2' && t3 === '2' && t4 === '2');

  const ocupado = estaOcupado(scope);
  const isNaoOcupado = (t1 === '2' && t2 === '2' && t3 === '2' && t4 === '2' && t5 === '2');

  const t9 = getVal(scope, 'T9_qtd_trabalhos');
  const showPrincipal = ocupado;
  const showSecundario = ocupado && (t9 === '2' || t9 === '3');
  const showOutros = ocupado && (t9 === '3');

  set('T9', ocupado);

  const posicao   = getVal(scope,'T12_posicao');
  const isDOM     = posicao === 'dom';
  const isMIL     = posicao === 'mil';
  const isPRIV    = posicao === 'priv';
  const isPUB     = posicao === 'pub';
  const isEMP     = posicao === 'emp';
  const isCP      = posicao === 'cp';
  const isNREM    = posicao === 'nrem';
  const nremTipo  = getVal(scope,'TNREM_subtipo');

  set('T10', showPrincipal); set('T11', showPrincipal); set('T12', showPrincipal);

  setDiv('bloco_dom',  showPrincipal && isDOM);
  setDiv('bloco_mil',  showPrincipal && isMIL);
  setDiv('bloco_priv', showPrincipal && isPRIV);
  setDiv('bloco_pub',  showPrincipal && isPUB);
  setDiv('bloco_emp',  showPrincipal && isEMP);
  setDiv('bloco_cp',   showPrincipal && isCP);
  setDiv('bloco_nrem', showPrincipal && isNREM);

  setDiv('sub_nrem_cp_emp',  showPrincipal && isNREM && nremTipo === 'cp_emp');
  setDiv('sub_nrem_empreg',  showPrincipal && isNREM && nremTipo === 'empreg');

  set('T25', showPrincipal && (isPRIV || isPUB));

  const tempNao   = getVal(scope,'T25_temporario') === '2';
  set('T28', showPrincipal && isPUB && tempNao);

  const needT29 = showPrincipal && (isDOM || isPRIV || (isPUB && getVal(scope,'T25_temporario') === '1'));
  set('T29', needT29);

  const ctpsNao  = getVal(scope,'T29_ctps') === '2';
  set('T29b', showPrincipal && isPRIV && ctpsNao);

  set('T32', showPrincipal && (
    isCP || isEMP ||
    (isDOM && ctpsNao) ||
    (isPRIV && ctpsNao) ||
    (isPUB && getVal(scope,'T25_temporario') === '1' && ctpsNao) ||
    (isPUB && tempNao && getVal(scope,'T28_estatutario') === '2')
  ));

  const localPRIV = getVal(scope,'T20_priv_local');
  set('T21_priv', showPrincipal && isPRIV && (localPRIV==='1'||localPRIV==='2'));
  const t21privNao = getVal(scope,'T21_priv_estab') === '2';
  set('T22_priv', showPrincipal && isPRIV && (localPRIV==='3' || t21privNao));
  set('T23_priv', showPrincipal && isPRIV && getVal(scope,'T22_priv_onde')==='1');

  const localEMP = getVal(scope,'T20_emp_local');
  set('T21_emp', showPrincipal && isEMP && (localEMP==='1'||localEMP==='2'));
  const t21empNao = getVal(scope,'T21_emp_estab') === '2';
  set('T22_emp', showPrincipal && isEMP && (localEMP==='3' || t21empNao));
  set('T23_emp', showPrincipal && isEMP && getVal(scope,'T22_emp_onde')==='1');

  const localCP = getVal(scope,'T20_cp_local');
  set('T21_cp', showPrincipal && isCP && (localCP==='1'||localCP==='2'));
  const t21cpNao = getVal(scope,'T21_cp_estab') === '2';
  set('T22_cp', showPrincipal && isCP && (localCP==='3' || t21cpNao));
  set('T23_cp', showPrincipal && isCP && getVal(scope,'T22_cp_onde')==='1');

  const temRend = showPrincipal && !isNREM;
  setDiv('badge_rend', showPrincipal);
  set('T33', temRend);
  set('T34', temRend);
  const temAdicional = showPrincipal && (isDOM || isMIL || isPRIV || isPUB);
  set('T33a', temAdicional);
  set('T33b', temAdicional);
  set('T34a', temAdicional);

  setDiv('badge_jorn', showPrincipal);
  set('T35', showPrincipal);
  set('T36', showPrincipal && getVal(scope,'T35_jornada_dia')==='2');
  set('T39', showPrincipal); set('T39a', showPrincipal);
  const t39aNao = getVal(scope,'T39a_mais') === '2';
  set('T39b', showPrincipal && t39aNao);
  const efetivo = getVal(scope,'T39a_mais')==='1' || getVal(scope,'T39b_menos')==='1';
  set('T39c', showPrincipal && efetivo);
  set('T40', showPrincipal);

  // =====================================================================
  // LÓGICA DO BLOCO SECUNDÁRIO (Q41-Q56) — corrigida conforme manual
  // =====================================================================
  setDiv('badge_sec', showSecundario);
  set('T41', showSecundario);
  set('T42', showSecundario);
  set('T43', showSecundario);

  const posSec = getVal(scope, 'T43_posicao');
  const isSecDOM  = posSec === 'dom';
  const isSecMIL  = posSec === 'mil';
  const isSecPRIV = posSec === 'priv';
  const isSecPUB  = posSec === 'pub';
  const isSecEMP  = posSec === 'emp';
  const isSecCP   = posSec === 'cp';
  const isSecNREM = posSec === 'nrem_cp_emp' || posSec === 'nrem_emp';

  // Q44 – Atividade: para todos exceto doméstico (que imputa automaticamente)
  set('T44_sec', showSecundario && !isSecDOM);

  // Q45 – Esfera: apenas público (com Municipal) e militar (sem Municipal)
  set('T45_sec_pub', showSecundario && isSecPUB);
  set('T45_sec_mil', showSecundario && isSecMIL);

  // Q46 – CNPJ: privado, CP, empregador e não remunerado (exclui doméstico, militar e público)
  set('T46_sec', showSecundario && (isSecPRIV || isSecCP || isSecEMP || isSecNREM));

  // Q47 – Estatutário: apenas público (após Q45)
  // Q47 = Sim → pula para Q50; Q47 = Não → segue Q48
  set('T47_sec', showSecundario && isSecPUB);
  const secEstatutarioSim = getVal(scope,'T47_sec_estatutario') === '1';
  const secEstatutarioNao = getVal(scope,'T47_sec_estatutario') === '2';

  // Q48 – CTPS: doméstico, privado, e público não-estatutário
  // Não remunerado vai para Q46 → pula para Q52 (conforme manual)
  const needT48sec = showSecundario && (
    isSecDOM ||
    isSecPRIV ||
    (isSecPUB && secEstatutarioNao)
  );
  set('T48_sec', needT48sec);
  const secCtpsNao = getVal(scope,'T48_sec_ctps') === '2';
  const secCtpsSim = getVal(scope,'T48_sec_ctps') === '1';

  // Q49 – Previdência: quem não tem CTPS + CP e Empregador (que não respondem CTPS)
  // Exclui: militares (pulo direto Q45→Q50), público estatutário (pulo Q47→Q50),
  //         doméstico/privado/público com CTPS assinada (pulo Q48→Q50)
  const needT49sec = showSecundario && (
    isSecCP || isSecEMP ||
    (isSecDOM && secCtpsNao) ||
    (isSecPRIV && secCtpsNao) ||
    (isSecPUB && secEstatutarioNao && secCtpsNao)
  );
  set('T49_sec', needT49sec);

  // Q50 – Rendimento habitual (todos exceto não remunerado)
  // Se somente benefícios (tipo='3') → pula para Q52
  const temRendSec = showSecundario && !isSecNREM;
  set('T50_sec', temRendSec);
  const secSomenteBeneficios = getVal(scope,'T50_sec_tipo') === '3';

  // Q51 – Rendimento do mês de referência (apenas se Q50 ≠ somente benefícios)
  set('T51_sec', temRendSec && !secSomenteBeneficios);

  // Q52 – Jornada diurna (5h-22h)? Para todos (incluindo não remunerado)
  set('T52_sec', showSecundario);
  const secNaoNaoturna = getVal(scope,'T52_sec_diurna') === '2';

  // Q53 – Totalmente noturna? Apenas se Q52 = Não
  set('T53_sec', showSecundario && secNaoNaoturna);

  // Q54 – Dias e horas efetivas na semana
  set('T54_sec', showSecundario);
  const secNaoExerceu = getVal(scope,'T54_sec_nao_exerceu') === '1';

  // Q55 – Confirmar horas normais (apenas se exerceu na semana)
  set('T55_sec', showSecundario && !secNaoExerceu);
  const secConfirmaNao = getVal(scope,'T55_sec_confirma') === '2';

  // Q56 – Horas normais por semana (se não exerceu na semana OU Q55 = Não)
  set('T56_sec', showSecundario && (secNaoExerceu || secConfirmaNao));

  // =====================================================================
  // LÓGICA DO BLOCO OUTROS TRABALHOS (Q57-Q62) — corrigida conforme manual
  // =====================================================================
  setDiv('bloco_outros_trab', showOutros);
  if (showOutros) {
    set('T57', true);
    set('T58', true);

    const t58opts = getVal(scope, 'T58_opcoes') || [];
    // Pula Q59 e vai direto para Q60 se somente benefícios (3) ou não remunerado (4)
    const skipT59 = t58opts.includes('3') || t58opts.includes('4');
    set('T59', !skipT59);

    // Q60 – dias e horas: sempre exibido
    set('T60', true);
    const t60NaoExerceu = getVal(scope, 'T60_nao_exerceu') === '1';

    // Q61 – Confirmar horas normais (apenas se exerceu na semana)
    set('T61', !t60NaoExerceu);
    const t61ConfirmaNao = getVal(scope, 'T61_confirma') === '2';

    // Q62 – Horas normais por semana (se não exerceu OU Q61 = Não)
    set('T62', t60NaoExerceu || t61ConfirmaNao);
  }

  // Bloco Comum Final de Subemprego (Aparece se for Ocupado)
  setDiv('badge_sub', showPrincipal);
  set('T63a', showPrincipal);
  const querMais = getVal(scope,'T63a_quer_mais') === '1';
  set('T64a', showPrincipal && querMais);
  const dispSim = getVal(scope,'T64a_disponivel') === '1';
  set('T65A', showPrincipal && querMais && dispSim);
  set('T66', showPrincipal && querMais && dispSim);

  setDiv('badge_proc', showPrincipal);
  set('T67', showPrincipal);
  const procOutro = showPrincipal && getVal(scope,'T67_proc_outro') === '1';
  set('T68a', procOutro);
  set('T69', procOutro);
  set('T70', procOutro);

  setDiv('bloco_nao_ocupado', isNaoOcupado);

  if (isNaoOcupado) {
    set('T70A', true);
    set('T71', true);
    const t71 = getVal(scope,'T71_providencia');

    set('T72a', t71 === '1');
    set('T76', t71 === '1');

    set('T73', t71 === '2');
    const t73 = getVal(scope,'T73_gostaria');

    set('T74a', t71 === '2' && t73 === '1');
    const t74a = getVal(scope,'T74a_motivo');

    set('T75a', t71 === '2' && t73 === '1' && t74a === '1');
    set('T75', t71 === '2' && t73 === '1' && t74a && t74a !== '1');

    const t75 = getVal(scope,'T75_ano_providencia');
    const showT77 = (t71 === '1') || (t74a === '1') || (t75 === '1');

    set('T77', showT77);
    const t77 = getVal(scope,'T77_poderia');
    set('T79', showT77 && t77 === '1');
    set('T78a', showT77 && t77 === '2');

    set('T80', true);
    const t80 = getVal(scope,'T80_algum_trab');
    set('T81', t80 === '2');

    const t81 = getVal(scope,'T81_ajudou');
    const showT82 = (t80 === '1' || t81 === '1');
    set('T82', showT82);

    const t82 = getVal(scope,'T82_trab_ano');
    set('T82a', showT82 && t82 === '1');

    const t82a = getVal(scope,'T82a_trab_3m');
    set('T94a', showT82 && t82 === '1' && t82a === '1');

    set('T97', showT82);
    set('T98', showT82);

  } else if (ocupado) {
    set('T97', showPrincipal);
    set('T98', showPrincipal);
  } else {
    set('T97', false);
    set('T98', false);
  }
}
