function renderTabsMoradores() {
  const bar = document.getElementById('tab-bar-moradores');
  if (!bar) return;
  bar.innerHTML = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const nome = getVal(sc,'M4_nome') || ('Morador ' + (i+1));

    const tabWrap = document.createElement('div');
    tabWrap.style.display = 'inline-flex';
    tabWrap.style.alignItems = 'center';
    tabWrap.style.gap = '4px';
    tabWrap.style.flexShrink = '0';

    const btn = document.createElement('button');
    btn.className = 'morador-tab' + (i === moradorAtual ? ' ativo' : '');
    if (getVal(sc,'M_concluido')) btn.classList.add('concluido');
    btn.textContent = nome.split(' ')[0] || ('Morador '+(i+1));
    btn.addEventListener('click', () => {
      moradorAtual = i;
      renderTabsMoradores();
      renderMoradorAtual();
      atualizarBotoes();
      renderEtiquetasMoradores();
    });
    tabWrap.appendChild(btn);

    if (i > 0) {
      const btnDel = document.createElement('button');
      btnDel.innerHTML = '🗑️';
      btnDel.style.background = 'transparent';
      btnDel.style.border = 'none';
      btnDel.style.cursor = 'pointer';
      btnDel.style.fontSize = '12px';
      btnDel.style.padding = '0 4px';
      btnDel.title = 'Excluir morador';
      btnDel.addEventListener('click', (e) => {
        e.stopPropagation();
        excluirMorador(i);
      });
      tabWrap.appendChild(btnDel);
    }
    bar.appendChild(tabWrap);
  }
  const addBtn = document.createElement('button');
  addBtn.id = 'btn-add-morador';
  addBtn.textContent = '+ Adicionar';
  addBtn.addEventListener('click', () => {
    totalMoradores++;
    dadosGlobais.moradores.push({});
    setVal(dadosGlobais.habitacao,'H_total_moradores', totalMoradores);
    moradorAtual = totalMoradores - 1;
    renderTabsMoradores();
    renderMoradorAtual();
    atualizarBotoes();
  });
  bar.appendChild(addBtn);
  renderEtiquetasMoradores();
}

