function renderTabsMEI() {
  const bar = document.getElementById('tab-bar-mei');
  if (!bar) return;
  bar.innerHTML = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    if (parseInt(getVal(sc,'M9_idade') || '0') < 14) continue;
    const nome = getVal(sc,'M4_nome') || ('Morador '+(i+1));
    const btn = document.createElement('button');
    const concMei = (dadosGlobais.mei[i] || {})['_concluido'];
    btn.className = 'morador-tab' + (i === moradorAtual ? ' ativo' : '') + (concMei ? ' concluido' : '');
    btn.textContent = nome.split(' ')[0];
    btn.addEventListener('click', () => {
      moradorAtual = i;
      renderTabsMEI();
      renderMEIMorador(document.getElementById('area-mei'));
      renderEtiquetasMoradores();
    });
    bar.appendChild(btn);
  }
}

function renderMEI() {
  const main = document.getElementById('main');
  main.innerHTML = '';
  const mh = document.createElement('div');
  mh.className = 'modulo-header';
  mh.innerHTML = `<div class="mod-icon">🏭</div><div><h2>Módulo MEI – Microempreendedor Individual</h2><p>Para moradores com 14 anos ou mais</p></div>`;
  main.appendChild(mh);
  const tabBar = document.createElement('div');
  tabBar.className = 'morador-tab-bar';
  tabBar.id = 'tab-bar-mei';
