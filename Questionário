function renderRendimentosMorador(area) {
  if (!area) return;
  area.innerHTML = '';
  const mscope = getMoradorScope(moradorAtual);
  const rscope = dadosGlobais.rendimentos[moradorAtual] || {};
  dadosGlobais.rendimentos[moradorAtual] = rscope;
  const nome = getVal(mscope,'M4_nome') || ('Morador '+(moradorAtual+1));

  const alerta = document.createElement('div'); alerta.className='alerta-info'; alerta.textContent=`Respondendo para: ${nome}`;
  area.appendChild(alerta);

  const rendimentos = [
    {id:'R1A', key:'R1A', label:'Benefício Assistencial de Prestação Continuada – BPC-LOAS'},
