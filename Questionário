function renderTabsEducacao() {
  const bar = document.getElementById('tab-bar-educ');
  if (!bar) return;
  bar.innerHTML = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const idade = parseInt(getVal(sc,'M9_idade') || '0');
    if (idade < 5) continue;
    const nome = getVal(sc,'M4_nome') || ('Morador ' + (i+1));
    const btn = document.createElement('button');
    const concEduc = (dadosGlobais.educacao[i] || {})['_concluido'];
    btn.className = 'morador-tab' + (i === moradorAtual ? ' ativo' : '') + (concEduc ? ' concluido' : '');
    btn.textContent = (nome.split(' ')[0] || ('Morador '+(i+1)));
    btn.addEventListener('click', () => {
      moradorAtual = i;
      renderTabsEducacao();
      renderEducacaoMorador();
      renderEtiquetasMoradores();
    });
