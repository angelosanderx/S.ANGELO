  const cardMEI3 = criarCard('MEI3','Nesse trabalho como MEI, era:', false,
    criarRadio(meisc,'MEI3_posicao',[{val:'1',label:'Conta própria (sem empregados)'},{val:'2',label:'Empregador (com empregados)'}])
  );
  if (getVal(meisc,'MEI2_trabalhou') !== '1') cardMEI3.classList.add('oculta');
  area.appendChild(cardMEI3);

  area.appendChild(criarCardInformante(meisc, 'MEI4', 'Quem prestou as informações sobre MEI?', [
    {val:'1',label:'A própria pessoa'},{val:'2',label:'Outro morador'},{val:'3',label:'Pessoa não moradora'}
  ]));
}

