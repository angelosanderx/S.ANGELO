<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PNAD Contínua – Questionário Eletrônico</title>
<style>
  /* ===================== TOKENS ===================== */
  :root {
    --azul-ibge: #1d4f8c;
    --azul-escuro: #0f2d52;
    --azul-claro: #dbeafe;
    --verde-ok: #16a34a;
    --vermelho-erro: #dc2626;
    --amarelo-aviso: #d97706;
    --cinza-bg: #f0f4f9;
    --cinza-borda: #c5d2e0;
    --cinza-texto: #374151;
    --branco: #ffffff;
    --sombra: 0 2px 8px rgba(0,0,0,0.10);
    --radius: 10px;
    --fonte: 'Segoe UI', Arial, sans-serif;
  }

  /* ===================== RESET ===================== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--fonte);
    background: var(--cinza-bg);
    color: var(--cinza-texto);
    font-size: 15px;
    min-height: 100vh;
  }

  /* ===================== HEADER ===================== */
  #app-header {
    background: var(--azul-escuro);
    color: var(--branco);
    padding: 14px 16px 10px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--sombra);
  }
  #app-header .logo-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #app-header .logo-ibge {
    width: 38px; height: 38px;
    background: var(--branco);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; color: var(--azul-escuro); font-size: 11px;
    letter-spacing: -0.5px; flex-shrink: 0;
  }
  #app-header h1 { font-size: 15px; font-weight: 700; line-height: 1.2; }
  #app-header p { font-size: 11px; opacity: 0.75; margin-top: 2px; }
  #progress-bar-wrap {
    margin-top: 10px;
    background: rgba(255,255,255,0.2);
    border-radius: 99px;
    height: 6px;
    overflow: hidden;
  }
  #progress-bar {
    height: 100%;
    background: #60a5fa;
    border-radius: 99px;
    transition: width 0.4s ease;
    width: 0%;
  }
  #progress-label {
    font-size: 10px;
    opacity: 0.7;
    margin-top: 3px;
    text-align: right;
  }

  /* ===================== MÓDULOS / NAV ===================== */
  #modulos-nav {
    display: flex;
    overflow-x: auto;
    gap: 6px;
    padding: 10px 14px;
    background: var(--azul-ibge);
    scrollbar-width: none;
  }
  #modulos-nav::-webkit-scrollbar { display: none; }
  .mod-btn {
    flex-shrink: 0;
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: none;
    border-radius: 20px;
    padding: 5px 13px;
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    font-family: var(--fonte);
    transition: background 0.2s;
  }
  .mod-btn.ativo { background: var(--branco); color: var(--azul-escuro); font-weight: 700; }
  .mod-btn.concluido { background: rgba(96,165,250,0.4); }

  /* ===================== MAIN CONTENT ===================== */
  #main {
    padding: 16px 14px 120px;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ===================== SEÇÃO DE MÓDULO ===================== */
  .modulo-header {
    background: var(--azul-ibge);
    color: var(--branco);
    padding: 12px 16px;
    border-radius: var(--radius) var(--radius) 0 0;
    margin-bottom: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .modulo-header .mod-icon {
    width: 32px; height: 32px;
    background: rgba(255,255,255,0.2);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0;
  }
  .modulo-header h2 { font-size: 15px; font-weight: 700; }
  .modulo-header p { font-size: 11px; opacity: 0.75; }

  /* ===================== CARD DE MORADOR ===================== */
  .morador-tab-bar {
    display: flex;
    overflow-x: auto;
    gap: 6px;
    padding: 10px 14px;
    background: var(--branco);
    border-bottom: 1px solid var(--cinza-borda);
    scrollbar-width: none;
  }
  .morador-tab-bar::-webkit-scrollbar { display: none; }
  .morador-tab {
    flex-shrink: 0;
    background: var(--cinza-bg);
    border: 1.5px solid var(--cinza-borda);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 12px;
    cursor: pointer;
    font-family: var(--fonte);
    transition: all 0.2s;
    color: var(--cinza-texto);
  }
  .morador-tab.ativo {
    background: var(--azul-ibge);
    color: var(--branco);
    border-color: var(--azul-ibge);
    font-weight: 700;
  }
  .morador-tab.concluido::after { content: ' ✓'; color: var(--verde-ok); }
  .morador-tab.ativo.concluido::after { color: #90cdf4; }
  #btn-add-morador {
    flex-shrink: 0;
    background: var(--verde-ok);
    color: var(--branco);
    border: none;
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 12px;
    cursor: pointer;
    font-family: var(--fonte);
  }

  /* ===================== QUESTÃO ===================== */
  .questao-card {
    background: var(--branco);
    border-radius: var(--radius);
    margin-bottom: 12px;
    box-shadow: var(--sombra);
    border: 1.5px solid var(--cinza-borda);
    overflow: hidden;
    transition: opacity 0.2s;
  }
  .questao-card.oculta { display: none; }
  .questao-header {
    background: var(--cinza-bg);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--cinza-borda);
  }
  .questao-num {
    background: var(--azul-ibge);
    color: var(--branco);
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .questao-titulo { font-size: 13px; font-weight: 600; color: var(--azul-escuro); }
  .questao-obrig {
    color: var(--vermelho-erro);
    font-size: 12px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .questao-body { padding: 12px 14px; }
  .questao-ajuda {
    font-size: 11px;
    color: #6b7280;
    background: #f9fafb;
    border-left: 3px solid var(--azul-claro);
    padding: 6px 10px;
    margin-bottom: 10px;
    border-radius: 0 4px 4px 0;
  }

  /* ===================== INPUTS ===================== */
  .opcoes-radio, .opcoes-check { display: flex; flex-direction: column; gap: 7px; }
  .opcao-label {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--cinza-bg);
    border: 1.5px solid var(--cinza-borda);
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .opcao-label:active { transform: scale(0.98); }
  .opcao-label.selecionada {
    background: var(--azul-claro);
    border-color: var(--azul-ibge);
    font-weight: 600;
    color: var(--azul-escuro);
  }
  .opcao-label input { display: none; }
  .opcao-check-visual {
    width: 20px; height: 20px;
    border-radius: 50%;
    border: 2px solid var(--cinza-borda);
    background: var(--branco);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }
  .opcao-label.selecionada .opcao-check-visual {
    background: var(--azul-ibge);
    border-color: var(--azul-ibge);
  }
  .opcao-check-visual::after {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--branco);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .opcao-label.selecionada .opcao-check-visual::after { opacity: 1; }
  .opcao-label.checkbox .opcao-check-visual { border-radius: 4px; }
  .opcao-label.checkbox.selecionada .opcao-check-visual::after {
    content: '✓';
    border-radius: 0;
    background: transparent;
    color: var(--branco);
    font-size: 12px;
    font-weight: 700;
    width: auto; height: auto;
  }

  input[type="text"], input[type="number"], input[type="date"], input[type="tel"], textarea, select {
    width: 100%;
    padding: 11px 13px;
    border: 1.5px solid var(--cinza-borda);
    border-radius: 8px;
    font-size: 15px;
    font-family: var(--fonte);
    color: var(--cinza-texto);
    background: var(--branco);
    appearance: auto;
    transition: border-color 0.2s;
  }
  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: var(--azul-ibge);
    box-shadow: 0 0 0 3px rgba(29,79,140,0.12);
  }
  .campo-grupo { display: flex; flex-direction: column; gap: 8px; margin-top: 6px; }
  .campo-label { font-size: 12px; color: #6b7280; margin-bottom: 2px; }

  /* ===================== SUBQUESTÃO ===================== */
  .subquestao {
    margin-top: 10px;
    padding: 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
  }
  .subquestao.oculta { display: none; }
  .subquestao-label { font-size: 13px; font-weight: 600; color: var(--azul-escuro); margin-bottom: 8px; }

  /* ===================== CHIPS MORADORES ===================== */
  #chips-moradores {
    display: none;
    position: fixed;
    bottom: 66px;
    left: 0; right: 0;
    background: #f8fafc;
    padding: 10px 14px;
    border-top: 1px solid var(--cinza-borda);
    gap: 8px;
    flex-wrap: wrap;
    z-index: 98;
    max-width: 600px;
    margin: 0 auto;
    box-shadow: 0 -2px 6px rgba(0,0,0,0.03);
  }

  .chip-morador {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--branco);
    border: 1.5px solid var(--cinza-borda);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 13px;
    color: var(--cinza-texto);
    transition: all 0.2s;
    flex-shrink: 0;
    cursor: pointer;
    font-family: var(--fonte);
  }
  .chip-morador.ativo {
    background: var(--azul-ibge);
    color: var(--branco);
    border-color: var(--azul-ibge);
    font-weight: 700;
  }
  .chip-morador.concluido .chip-check {
    color: var(--verde-ok);
    font-weight: 900;
    margin-left: 2px;
  }
  .chip-morador.ativo.concluido .chip-check {
    color: #90cdf4;
  }

  /* ===================== BOTÕES NAVEGAÇÃO ===================== */
  #nav-btns {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--branco);
    padding: 10px 16px;
    border-top: 1px solid var(--cinza-borda);
    display: flex;
    gap: 10px;
    z-index: 99;
    max-width: 600px;
    margin: 0 auto;
  }
  .btn {
    flex: 1;
    padding: 13px;
    border: none;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--fonte);
    transition: transform 0.1s, opacity 0.2s;
  }
  .btn:active { transform: scale(0.97); }
  .btn-sec { background: var(--cinza-bg); color: var(--cinza-texto); border: 1.5px solid var(--cinza-borda); }
  .btn-prim { background: var(--azul-ibge); color: var(--branco); }
  .btn-verde { background: var(--verde-ok); color: var(--branco); }
  .btn-disabled { opacity: 0.45; pointer-events: none; }

  /* ===================== RESUMO ===================== */
  #tela-resumo { display: none; padding: 16px 14px 30px; max-width: 600px; margin: 0 auto; }
  .resumo-titulo {
    background: var(--verde-ok);
    color: var(--branco);
    padding: 14px 18px;
    border-radius: var(--radius);
    margin-bottom: 14px;
    text-align: center;
  }
  .resumo-titulo h2 { font-size: 18px; margin-bottom: 4px; }
  .resumo-titulo p { font-size: 12px; opacity: 0.85; }
  .resumo-secao { margin-bottom: 14px; }
  .resumo-secao-titulo {
    font-size: 13px;
    font-weight: 700;
    color: var(--azul-ibge);
    border-bottom: 2px solid var(--azul-claro);
    padding-bottom: 5px;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .resumo-item { font-size: 13px; margin-bottom: 5px; line-height: 1.5; }
  .resumo-item strong { color: var(--azul-escuro); }
  #resumo-texto-box {
    background: #f8fafc;
    border: 1px solid var(--cinza-borda);
    border-radius: var(--radius);
    padding: 14px;
    margin-bottom: 14px;
    font-size: 12.5px;
    line-height: 1.65;
    white-space: pre-wrap;
    max-height: 250px;
    overflow-y: auto;
  }
  .resumo-acoes { display: flex; flex-direction: column; gap: 10px; }
  .btn-acao {
    padding: 13px;
    border: none;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--fonte);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .btn-copiar { background: var(--azul-claro); color: var(--azul-escuro); }
  .btn-pdf { background: var(--vermelho-erro); color: var(--branco); }
  .btn-wpp { background: #25D366; color: var(--branco); }
  .btn-reiniciar { background: var(--cinza-bg); color: var(--cinza-texto); border: 1.5px solid var(--cinza-borda); }

  /* ===================== OVERLAY LOADING ===================== */
  #loading { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 999; align-items: center; justify-content: center; }
  #loading.ativo { display: flex; }
  .spinner {
    width: 46px; height: 46px;
    border: 4px solid rgba(255,255,255,0.3);
    border-top-color: var(--branco);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ===================== RESPONSIVO ===================== */
  @media (min-width: 601px) {
    #nav-btns, #chips-moradores { left: 50%; right: auto; transform: translateX(-50%); width: 600px; }
  }

  /* ===================== MISC ===================== */
  .badge-modulo {
    display: inline-block;
    background: var(--azul-claro);
    color: var(--azul-escuro);
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    margin-bottom: 8px;
  }
  .alerta-info {
    background: #fffbeb;
    border: 1px solid #fcd34d;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 13px;
    color: #92400e;
    margin-bottom: 12px;
  }
  .resumo-morador-bloco {
    border: 1.5px solid var(--cinza-borda);
    border-radius: var(--radius);
    margin-bottom: 12px;
    overflow: hidden;
  }
  .resumo-morador-header {
    background: var(--azul-ibge);
    color: var(--branco);
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 700;
  }
  .resumo-morador-body { padding: 10px 14px; }

  /* ===================== PRÉ-CADASTRO MODAL ===================== */
  #modal-precadastro {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.5); z-index: 2000;
    align-items: center; justify-content: center; padding: 20px;
  }
  #modal-precadastro.ativo { display: flex; }
  .modal-pc-content {
    background: var(--branco); padding: 20px;
    border-radius: var(--radius); width: 100%; max-width: 500px;
    box-shadow: var(--sombra); max-height: 80vh; overflow-y: auto;
  }
  .modal-pc-content h3 { font-size: 15px; color: var(--azul-escuro); margin-bottom: 6px; }
  .modal-pc-content .questao-ajuda { margin-bottom: 14px; }
  .modal-pc-campos { display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px; }
  .modal-pc-campos .campo-label { font-size: 12px; color: #6b7280; margin-bottom: 3px; font-weight: 600; }
  .modal-pc-btns { display: flex; gap: 10px; }
  #btn-abrir-precadastro {
    margin-top: 10px; width: 100%;
    padding: 10px; border: 1.5px dashed var(--azul-ibge);
    background: var(--azul-claro); color: var(--azul-escuro);
    border-radius: 8px; cursor: pointer; font-size: 13px;
    font-weight: 700; font-family: var(--fonte);
  }
  #btn-abrir-precadastro:active { opacity: 0.8; }
  #resumo-precadastro {
    margin-top: 8px; font-size: 12px; color: var(--cinza-texto);
    background: #f0fdf4; border: 1px solid #86efac;
    border-radius: 6px; padding: 8px 12px; display: none;
  }

  /* ===================== OBSERVAÇÕES ===================== */
  #btn-obs-float {
    position: fixed; bottom: 80px; right: 20px; z-index: 1000;
    background: var(--azul-ibge); color: var(--branco);
    padding: 10px 15px; border-radius: 30px; border: none;
    cursor: pointer; box-shadow: var(--sombra);
    font-weight: 700; font-size: 12px; font-family: var(--fonte);
  }
  #btn-obs-float:active { transform: scale(0.96); }
  #modal-obs {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.5); z-index: 2000;
    align-items: center; justify-content: center; padding: 20px;
  }
  #modal-obs.ativo { display: flex; }
  .modal-obs-content {
    background: var(--branco); padding: 20px;
    border-radius: var(--radius); width: 100%; max-width: 500px;
    box-shadow: var(--sombra);
  }
  .modal-obs-content h3 { font-size: 15px; color: var(--azul-escuro); margin-bottom: 10px; }
  .modal-obs-content textarea {
    width: 100%; height: 150px; margin: 10px 0;
    padding: 10px; border: 1.5px solid var(--cinza-borda);
    border-radius: 8px; font-size: 14px; font-family: var(--fonte);
    resize: vertical;
  }
  .modal-obs-content textarea:focus {
    outline: none; border-color: var(--azul-ibge);
    box-shadow: 0 0 0 3px rgba(29,79,140,0.12);
  }
  .modal-obs-btns { display: flex; gap: 10px; }
</style>
</head>
<body>

<div id="app-header">
  <div class="logo-row">
    <div class="logo-ibge">IBGE</div>
    <div>
      <h1>PNAD Contínua</h1>
      <p>Pesquisa Nacional por Amostra de Domicílios</p>
    </div>
  </div>
  <div id="progress-bar-wrap"><div id="progress-bar"></div></div>
  <div id="progress-label">0% concluído</div>
</div>

<div id="modulos-nav">
  <button class="mod-btn ativo" onclick="irParaModulo(0)">🏠 Habitação</button>
  <button class="mod-btn" onclick="irParaModulo(1)">👥 Moradores</button>
  <button class="mod-btn" onclick="irParaModulo(2)">📚 Educação</button>
  <button class="mod-btn" onclick="irParaModulo(3)">💼 Trabalho</button>
  <button class="mod-btn" onclick="irParaModulo(4)">🏭 MEI</button>
  <button class="mod-btn" onclick="irParaModulo(5)">💰 Rendimentos</button>
</div>

<div id="loading"><div class="spinner"></div></div>

<div id="modal-precadastro">
  <div class="modal-pc-content">
    <h3>👥 Nomes dos moradores</h3>
    <div class="questao-ajuda">Pré-cadastre o nome completo de todos os moradores antes de iniciar o questionário individual.</div>
    <div class="modal-pc-campos" id="modal-pc-campos"></div>
    <div class="modal-pc-btns">
      <button class="btn btn-verde" onclick="confirmarPreCadastro()">✓ Confirmar</button>
      <button class="btn btn-sec" onclick="fecharModalPreCadastro()">Fechar</button>
    </div>
  </div>
</div>

<button id="btn-obs-float" onclick="abrirModalObs()">📝 Obs.</button>
<div id="modal-obs">
  <div class="modal-obs-content">
    <h3>📝 Observações Gerais</h3>
    <textarea id="obs-textarea" placeholder="Digite aqui observações sobre esta entrevista..."></textarea>
    <div class="modal-obs-btns">
      <button class="btn btn-prim" onclick="salvarObs()">Salvar</button>
      <button class="btn btn-sec" onclick="fecharModalObs()">Fechar</button>
    </div>
  </div>
</div>

<div id="main"></div>

<div id="tela-resumo">
  <div class="resumo-titulo">
    <h2>✅ Questionário Concluído</h2>
    <p>Todas as seções foram preenchidas com sucesso.</p>
  </div>
  <div id="resumo-html"></div>
  <div style="font-size:13px;font-weight:700;color:#374151;margin-bottom:6px;">Texto do Resumo (para copiar/enviar):</div>
  <div id="resumo-texto-box"></div>
  <div class="resumo-acoes">
    <button class="btn-acao btn-copiar" onclick="copiarResumo()">📋 Copiar Resumo</button>
    <button class="btn-acao btn-pdf" onclick="gerarPDF()">📄 Baixar PDF</button>
    <button class="btn-acao btn-wpp" onclick="enviarWhatsApp()">💬 Enviar por WhatsApp</button>
    <button class="btn-acao btn-reiniciar" onclick="reiniciar()">🔄 Preencher Novo</button>
  </div>
</div>

<div id="chips-moradores"></div>

<div id="nav-btns">
  <button class="btn btn-sec" id="btn-prev" onclick="navAnterior()">← Anterior</button>
  <button class="btn btn-prim" id="btn-next" onclick="navProximo()">Próximo →</button>
</div>

<script>
// ============================================================
// ESTADO GLOBAL
// ============================================================
const STORAGE_KEY = 'pnadc_dados_v2';
let dadosGlobais = {
  habitacao: {},
  moradores: [],
  educacao: [],
  trabalho: [],
  mei: [],
  rendimentos: [],
  entrevistador: {},
  observacoes: { texto: '' }
};
let moduloAtual = 0;
let moradorAtual = 0;
let totalMoradores = 1;
let responsavelNome = 'o Responsável';

// ============================================================
// DEFINIÇÃO DOS MÓDULOS
// ============================================================
const MODULOS = [
  { id: 'habitacao', label: 'Habitação', icon: '🏠', render: renderHabitacao },
  { id: 'moradores', label: 'Moradores', icon: '👥', render: renderMoradores },
  { id: 'educacao', label: 'Educação', icon: '📚', render: renderEducacao },
  { id: 'trabalho', label: 'Trabalho', icon: '💼', render: renderTrabalho },
  { id: 'mei', label: 'MEI', icon: '🏭', render: renderMEI },
  { id: 'rendimentos', label: 'Rendimentos', icon: '💰', render: renderRendimentos },
];

// ============================================================
// PERSISTÊNCIA LOCAL
// ============================================================
function salvarDados() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(dadosGlobais)); } catch(e) {}
}
function carregarDados() {
  try {
    const s = localStorage.getItem(STORAGE_KEY);
    if (s) {
      dadosGlobais = JSON.parse(s);
      totalMoradores = Math.max(1, dadosGlobais.moradores.length || 1);
    }
  } catch(e) {}
}

// ============================================================
// HELPERS DE CAMPO
// ============================================================
function getVal(scope, key) {
  if (!scope) return '';
  return scope[key] !== undefined ? scope[key] : '';
}
function setVal(scope, key, val) {
  scope[key] = val;
  salvarDados();
}
function getMoradorScope(idx) {
  while (dadosGlobais.moradores.length <= idx) dadosGlobais.moradores.push({});
  return dadosGlobais.moradores[idx];
}
function etapaAtual() {
  return getVal(dadosGlobais.habitacao, 'ET0_etapa') || '1';
}

// ============================================================
// COMPONENTE: ETIQUETAS DE MORADORES
// ============================================================
function renderEtiquetasMoradores() {
  const cont = document.getElementById('chips-moradores');
  if (!cont) return;

  if (moduloAtual === 0) {
    cont.style.display = 'none';
    return;
  }

  cont.style.display = 'flex';
  cont.innerHTML = '';

  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const idade = parseInt(getVal(sc,'M9_idade') || '0');

    if (moduloAtual === 2 && idade < 5) continue;
    if (moduloAtual === 3 && idade < 14) continue;
    if (moduloAtual === 4 && idade < 14) continue;

    const nome = getVal(sc, 'M4_nome') || ('Morador ' + (i+1));
    const pNome = nome.split(' ')[0];
    const concluido = getVal(sc, 'M_concluido');

    const chip = document.createElement('button');
    chip.className = 'chip-morador' + (i === moradorAtual ? ' ativo' : '') + (concluido ? ' concluido' : '');

    let html = `<span>👤 ${pNome}</span>`;
    if (concluido) {
      html += `<span class="chip-check">✓</span>`;
    }
    chip.innerHTML = html;

    chip.addEventListener('click', () => {
      if (moradorAtual === i) return;
      moradorAtual = i;

      if (moduloAtual === 1) {
        renderTabsMoradores();
        renderMoradorAtual();
        atualizarBotoes();
      } else if (moduloAtual === 2) {
        renderTabsEducacao();
        renderEducacaoMorador();
      } else if (moduloAtual === 3) {
        renderTabsTrabalho();
        renderTrabalhoMorador();
      } else if (moduloAtual === 4) {
        renderTabsMEI();
        renderMEIMorador(document.getElementById('area-mei'));
      } else if (moduloAtual === 5) {
        renderTabsRendimentos();
        renderRendimentosMorador(document.getElementById('area-rend'));
      }
      renderEtiquetasMoradores();
    });

    cont.appendChild(chip);
  }
}

// ============================================================
// CONSTRUÇÃO DE COMPONENTES
// ============================================================
function criarRadio(scope, key, opcoes, onChange) {
  const div = document.createElement('div');
  div.className = 'opcoes-radio';
  opcoes.forEach(op => {
    const label = document.createElement('label');
    label.className = 'opcao-label';
    if (getVal(scope, key) === op.val) label.classList.add('selecionada');
    const inp = document.createElement('input');
    inp.type = 'radio'; inp.name = key + '_' + Math.random().toString(36).slice(2);
    inp.value = op.val;
    if (getVal(scope, key) === op.val) inp.checked = true;
    const vis = document.createElement('div');
    vis.className = 'opcao-check-visual';
    const txt = document.createElement('span');
    txt.textContent = op.label;
    label.appendChild(inp); label.appendChild(vis); label.appendChild(txt);
    label.addEventListener('click', () => {
      div.querySelectorAll('.opcao-label').forEach(l => l.classList.remove('selecionada'));
      label.classList.add('selecionada');
      setVal(scope, key, op.val);
      if (onChange) onChange(op.val);
    });
    div.appendChild(label);
  });
  return div;
}

function criarCheckMulti(scope, key, opcoes, onChange) {
  const div = document.createElement('div');
  div.className = 'opcoes-check';
  opcoes.forEach(op => {
    const vals = getVal(scope, key) || [];
    const label = document.createElement('label');
    label.className = 'opcao-label checkbox';
    if (vals.includes(op.val)) label.classList.add('selecionada');
    const inp = document.createElement('input');
    inp.type = 'checkbox'; inp.value = op.val;
    if (vals.includes(op.val)) inp.checked = true;
    const vis = document.createElement('div');
    vis.className = 'opcao-check-visual';
    const txt = document.createElement('span');
    txt.textContent = op.label;
    label.appendChild(inp); label.appendChild(vis); label.appendChild(txt);
    label.addEventListener('click', () => {
      inp.checked = !inp.checked;
      const cur = getVal(scope, key) || [];
      if (inp.checked) { if (!cur.includes(op.val)) cur.push(op.val); label.classList.add('selecionada'); }
      else { const i = cur.indexOf(op.val); if (i > -1) cur.splice(i,1); label.classList.remove('selecionada'); }
      setVal(scope, key, cur);
      if (onChange) onChange(cur);
    });
    div.appendChild(label);
  });
  return div;
}

function validarESalvarMorador() {
  const idx = moradorAtual;
  const scope = getMoradorScope(idx);

  const nome = getVal(scope, 'M4_nome');
  if (!nome || nome.trim() === '') {
    alert('Por favor, preencha o Nome do morador antes de avançar.');
    return false;
  }

  if (idx > 0) {
    const condicao = getVal(scope, 'M5_condicao');
    if (!condicao) {
      alert('Por favor, selecione a relação deste morador com o responsável.');
      return false;
    }
    if (condicao === '6') {
      const condicaoOutro = getVal(scope, 'M5_condicao_outro');
      if (!condicaoOutro || condicaoOutro.trim() === '') {
        alert('Por favor, especifique a relação (Outros) com o responsável.');
        return false;
      }
    }
  }

  setVal(scope, 'M_concluido', true);
  return true;
}

function excluirMorador(index) {
  if (totalMoradores <= 1 || index === 0) return;

  const confirmacao = confirm("Tem certeza que deseja excluir este morador?\nTodos os dados relacionados a ele serão removidos.");
  if (!confirmacao) return;

  dadosGlobais.moradores.splice(index, 1);
  if (dadosGlobais.educacao.length > index) dadosGlobais.educacao.splice(index, 1);
  if (dadosGlobais.trabalho.length > index) dadosGlobais.trabalho.splice(index, 1);
  if (dadosGlobais.mei.length > index) dadosGlobais.mei.splice(index, 1);
  if (dadosGlobais.rendimentos.length > index) dadosGlobais.rendimentos.splice(index, 1);

  totalMoradores--;
  setVal(dadosGlobais.habitacao, 'H_total_moradores', totalMoradores);

  const inpTotal = document.querySelector('input[placeholder="Ex: 4"]');
  if (inpTotal) inpTotal.value = totalMoradores;

  if (moradorAtual >= totalMoradores) {
    moradorAtual = totalMoradores - 1;
  }

  salvarDados();
  renderTabsMoradores();
  renderMoradorAtual();
  atualizarBotoes();
}

function criarInput(scope, key, tipo, placeholder, onChange) {
  const inp = document.createElement('input');
  inp.type = tipo || 'text'; inp.placeholder = placeholder || '';
  inp.value = getVal(scope, key);
  inp.addEventListener('input', () => {
    setVal(scope, key, inp.value);
    if (onChange) onChange(inp.value);
  });
  return inp;
}

function criarCard(num, titulo, obrig, corpo, ajuda) {
  const card = document.createElement('div');
  card.className = 'questao-card';
  card.id = 'q_' + num;
  const header = document.createElement('div');
  header.className = 'questao-header';
  const numEl = document.createElement('span');
  numEl.className = 'questao-num'; numEl.textContent = num;

  // Tratamento para adicionar o nome do morador no final da pergunta
  let tituloFinal = titulo;
  // Aplica a regra para todos os módulos exceto Habitação (0), ignorando a questão de controle geral 'M1' e 'ENT1'
  if (moduloAtual > 0 && num !== 'M1' && num !== 'ENT1') {
    const sc = getMoradorScope(moradorAtual);
    const nomeCompleto = getVal(sc, 'M4_nome') || ('Morador ' + (moradorAtual + 1));
    tituloFinal = `${titulo} (${nomeCompleto})`;
  }

  const titEl = document.createElement('span');
  titEl.className = 'questao-titulo'; titEl.textContent = tituloFinal;
  header.appendChild(numEl); header.appendChild(titEl);
  if (obrig) {
    const ob = document.createElement('span');
    ob.className = 'questao-obrig'; ob.textContent = '* obrig.';
    header.appendChild(ob);
  }
  card.appendChild(header);
  const body = document.createElement('div');
  body.className = 'questao-body';
  if (ajuda) {
    const aj = document.createElement('div');
    aj.className = 'questao-ajuda'; aj.textContent = ajuda;
    body.appendChild(aj);
  }
  body.appendChild(corpo);
  card.appendChild(body);
  return card;
}

function mostrarOcultar(el, mostrar) {
  if (!el) return;
  if (mostrar) el.classList.remove('oculta');
  else el.classList.add('oculta');
}

function criarCardInformante(scope, qId, labelText, optionsArr) {
  const div = document.createElement('div');
  div.className = 'campo-grupo';

  const atualizarSub = (v) => {
    const subOutroMorador = document.getElementById('sub_' + qId + '_morador');
    const subNaoMorador   = document.getElementById('sub_' + qId + '_naomorador');
    if (subOutroMorador) mostrarOcultar(subOutroMorador, v === '2');
    if (subNaoMorador)   mostrarOcultar(subNaoMorador,   v === '3');
  };

  div.appendChild(criarRadio(scope, qId + '_informante', optionsArr, atualizarSub));

  // Sub: Outro morador — lista de moradores cadastrados
  const subMorador = document.createElement('div');
  subMorador.id = 'sub_' + qId + '_morador';
  const valAtual = getVal(scope, qId + '_informante');
  subMorador.className = 'subquestao' + (valAtual === '2' ? '' : ' oculta');
  const lblMorador = document.createElement('div');
  lblMorador.className = 'subquestao-label';
  lblMorador.textContent = 'Selecione o morador:';
  subMorador.appendChild(lblMorador);
  const sel = document.createElement('select');
  sel.style.marginTop = '4px';
  const optVazia = document.createElement('option');
  optVazia.value = ''; optVazia.textContent = '— Selecione —';
  sel.appendChild(optVazia);
  for (let i = 0; i < totalMoradores; i++) {
    if (i === moradorAtual) continue; // Exclui a própria pessoa da lista de outros moradores
    const sc = getMoradorScope(i);
    const nome = getVal(sc, 'M4_nome') || ('Morador ' + (i + 1));
    const opt = document.createElement('option');
    opt.value = nome; opt.textContent = nome;
    if (getVal(scope, qId + '_inf_nome') === nome) opt.selected = true;
    sel.appendChild(opt);
  }
  sel.addEventListener('change', () => { setVal(scope, qId + '_inf_nome', sel.value); });
  subMorador.appendChild(sel);
  div.appendChild(subMorador);

  // Sub: Pessoa não moradora — campo de texto livre
  const subNaoMorador = document.createElement('div');
  subNaoMorador.id = 'sub_' + qId + '_naomorador';
  subNaoMorador.className = 'subquestao' + (valAtual === '3' ? '' : ' oculta');
  const lblNaoMorador = document.createElement('div');
  lblNaoMorador.className = 'subquestao-label';
  lblNaoMorador.textContent = 'Nome da pessoa:';
  subNaoMorador.appendChild(lblNaoMorador);
  subNaoMorador.appendChild(criarInput(scope, qId + '_inf_nome', 'text', 'Digite o nome'));
  div.appendChild(subNaoMorador);

  return criarCard(qId, labelText, false, div);
}

// ============================================================
// MÓDULO 1 – HABITAÇÃO
// ============================================================
function renderHabitacao() {
  const main = document.getElementById('main');
  main.innerHTML = '';
  const scope = dadosGlobais.habitacao;

  const mh = document.createElement('div');
