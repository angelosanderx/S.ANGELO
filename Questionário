      ['R1A','BPC/LOAS'],['R2A','Bolsa Família/AuxBrasil'],['R3A','Outros prog. sociais'],
      ['R4A','Aposentadoria/Pensão INSS'],['R5A','Seguro-desemplego/defeso'],
      ['R6A','Pensão alimentícia/doação'],['R7A','Aluguel/arrendamento'],['R8A','Outros rendimentos']
    ];
    let temRenda = false;
    rendNomes.forEach(([k, label]) => {
      if (rv(k+'_sim') === '1') { linhas.push(`${label}: R$ ${rv(k+'_val')}`); temRenda = true; }
    });
    if (!temRenda) linhas.push('Sem rendimentos adicionais declarados');
  }

  linhas.push('');
  const modoMap = {'1':'Presencial','2':'Por telefone','3':'Misto (presencial + telefone)'};
  linhas.push(`Modo de aplicação: ${modoMap[getVal(dadosGlobais.entrevistador,'ENT1_modo')] || '—'}`);
  linhas.push('');

  if (dadosGlobais.observacoes && dadosGlobais.observacoes.texto.trim() !== '') {
    linhas.push('=== OBSERVAÇÕES GERAIS ===');
    linhas.push(dadosGlobais.observacoes.texto);
    linhas.push('');
  }

  linhas.push(`[Gerado em: ${new Date().toLocaleString('pt-BR')}]`);

  return linhas.join('\n');
}

// ============================================================
// FINALIZAR E EXIBIR RESUMO
// ============================================================
function finalizarQuestionario() {
  document.getElementById('loading').classList.add('ativo');
  setTimeout(() => {
    document.getElementById('loading').classList.remove('ativo');
    document.getElementById('main').style.display = 'none';
    document.getElementById('nav-btns').style.display = 'none';

    // Ocultar os chips caso fiquem sobrepondo o resumo final
    const chipsCont = document.getElementById('chips-moradores');
    if (chipsCont) chipsCont.style.display = 'none';

    document.getElementById('tela-resumo').style.display = 'block';

    const texto = gerarResumo();
    document.getElementById('resumo-texto-box').textContent = texto;

    const html = gerarResumoHTML();
    document.getElementById('resumo-html').innerHTML = html;

    window.scrollTo({top:0, behavior:'smooth'});
  }, 800);
}

function gerarResumoHTML() {
  const h = dadosGlobais.habitacao;
  const gv = (k) => getVal(h, k) || '—';
  let out = '';

  const secao = (titulo, conteudo) => `<div class="resumo-secao"><div class="resumo-secao-titulo">${titulo}</div>${conteudo}</div>`;
  const item = (l, v) => `<div class="resumo-item"><strong>${l}:</strong> ${v || '—'}</div>`;

  const tipoMap={'1':'Casa','2':'Apartamento'};
  const condMap={'1':'Próprio já pago','2':'Próprio financiando','3':'Alugado','4':'Cedido empregador','5':'Cedido familiar','6':'Cedido outra','7':'Outra condição'};

  out += secao('🏠 Habitação',
    item('Etapa da Entrevista', gv('ET0_etapa')) +
    item('Setor/Domicílio', gv('H0_setor')) +
    item('Endereço', gv('H0A_endereco')) +
    item('Informante', gv('H0B_informante')) +
    item('Telefone', gv('H0C_telefone')) +
    (etapaAtual() === '1' ? (
      item('Tipo', tipoMap[gv('H1_tipo')]) +
      item('Cômodos', gv('H5_comodos')) + item('Dormitórios', gv('H6_dormitorios')) +
      item('Água', ({1:'Rede geral',2:'Poço/Nascente',3:'Cisterna',4:'Carro-pipa'}[gv('H7_agua')])) +
      item('Casas de banho', gv('H11A_banheiros')) +
      item('Internet', gv('H29_internet')==='1'?'Sim':'Não') +
      item('Automóvel', gv('H31_automovel')==='1'?'Sim':'Não')
    ) : '') +
    item('Condição', condMap[gv('H17_condicao')])
  );

  let morHtml = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const vv = (k) => getVal(sc, k) || '—';
    const corMap={'1':'Branca','2':'Preta','3':'Amarela','4':'Parda','5':'Indígena'};
    morHtml += `<div class="resumo-morador-bloco">
      <div class="resumo-morador-header">Morador ${i+1}: ${vv('M4_nome')}</div>
      <div class="resumo-morador-body">
        ${item('Sexo', vv('M7_sexo')==='1'?'Masculino':'Feminino')}
        ${item('Idade', vv('M9_idade')+' anos')}
        ${item('Cor/raça', corMap[vv('M10_cor')])}
      </div>
    </div>`;
  }
  out += secao('👥 Moradores', morHtml);

  let trabHtml = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    if (parseInt(getVal(sc,'M9_idade') || '0') < 14) continue;
    const tsc = dadosGlobais.trabalho[i] || {};
    const vv = (k) => getVal(tsc, k) || '—';
    const ocup = estaOcupado(tsc);

    let tBody = item('Status', ocup ? 'OCUPADO' : 'NÃO OCUPADO');
    if (ocup) {
        tBody += item('Ocupação', vv('T10_ocupacao'));
        const posMap={'dom':'Trabalhador doméstico','mil':'Militar','priv':'Empregado privado','pub':'Empregado público','emp':'Empregador','cp':'Conta própria','nrem':'Não remunerado'};
        tBody += item('Posição', posMap[vv('T12_posicao')] || vv('T12_posicao'));
        tBody += item('Rendimento Bruto (habitual)', 'R$ ' + vv('T33_valor'));

        if (vv('T9_qtd_trabalhos') === '2' || vv('T9_qtd_trabalhos') === '3') {
          tBody += `<div style="margin-top:8px; border-top:1px dashed #ccc; padding-top:8px;"><strong>Trabalho Secundário:</strong></div>`;
          tBody += item('Ocupação Secundária', vv('T41_ocupacao'));
          tBody += item('Posição Secundária', posMap[vv('T43_posicao')] || vv('T43_posicao'));
        }

        if (vv('T9_qtd_trabalhos') === '3') {
          tBody += `<div style="margin-top:8px; border-top:1px dashed #ccc; padding-top:8px;"><strong>Outros Trabalhos (3 ou mais):</strong></div>`;
          tBody += item('Contribuinte INSS', vv('T57_previdencia') === '1' ? 'Sim' : 'Não');

          const t58 = getVal(tsc, 'T58_opcoes') || [];
          if(t58.includes('3')) tBody += item('Rendimento', 'Somente em benefícios');
          else if(t58.includes('4')) tBody += item('Rendimento', 'Não remunerado');
          else {
              if(t58.includes('1')) tBody += item('Rendimento (Dinheiro)', 'R$ ' + vv('T58_valor_dinheiro'));
              if(t58.includes('2')) tBody += item('Rendimento (Produtos)', 'R$ ' + vv('T58_valor_produtos'));
          }
          if(!t58.includes('3') && !t58.includes('4')) {
              tBody += item('Horas semanais', vv('T62_horas'));
          }
        }
    }
    trabHtml += `<div class="resumo-morador-bloco">
      <div class="resumo-morador-header">${getVal(sc,'M4_nome')||'Morador '+(i+1)}</div>
      <div class="resumo-morador-body">${tBody}</div>
    </div>`;
  }
  if(trabHtml) out += secao('💼 Trabalho', trabHtml);

  if (dadosGlobais.observacoes && dadosGlobais.observacoes.texto.trim() !== '') {
    out += secao('📝 Observações Gerais',
      `<div class="resumo-item">${dadosGlobais.observacoes.texto.replace(/\n/g, '<br>')}</div>`
    );
  }

  return out;
}

// ============================================================
// AÇÕES DO RESUMO
// ============================================================
function copiarResumo() {
  const texto = gerarResumo();
  navigator.clipboard.writeText(texto).then(() => { alert('✅ Resumo copiado para a área de transferência!'); }).catch(() => {
    const ta = document.createElement('textarea'); ta.value = texto; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); alert('✅ Resumo copiado!');
  });
}

function gerarPDF() {
  const texto = gerarResumo();
  const janela = window.open('', '_blank');
  if (!janela) { alert('Permita pop-ups para gerar o PDF.'); return; }
  janela.document.write(`<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><title>PNAD Contínua – Resumo</title><style>body{font-family:Arial,sans-serif;font-size:12px;line-height:1.6;color:#222;padding:20px;}h1{font-size:16px;color:#1d4f8c;border-bottom:2px solid #1d4f8c;padding-bottom:6px;margin-bottom:14px;}pre{white-space:pre-wrap;word-wrap:break-word;}@media print{button{display:none!important;}}</style></head><body><h1>PNAD Contínua – Resumo do Questionário</h1><button onclick="window.print()" style="margin-bottom:16px;padding:8px 18px;background:#1d4f8c;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;">🖨️ Imprimir / Salvar PDF</button><pre>${texto.replace(/</g,'&lt;')}</pre></body></html>`);
  janela.document.close();
}

function enviarWhatsApp() {
  const texto = gerarResumo();
  const linhas = texto.split('\n').slice(0, 40).join('\n') + '\n...(resumo completo disponível)';
  const encoded = encodeURIComponent('📊 *PNAD Contínua – Resumo*\n\n' + linhas);
  window.open('https://wa.me/?text=' + encoded, '_blank');
}

function reiniciar() {
  if (!confirm('Deseja iniciar um novo questionário? Os dados atuais serão apagados.')) return;
  dadosGlobais = { habitacao:{}, moradores:[], educacao:[], trabalho:[], mei:[], rendimentos:[], entrevistador:{} };
  totalMoradores = 1; moradorAtual = 0; salvarDados();
  document.getElementById('tela-resumo').style.display = 'none'; document.getElementById('main').style.display = 'block'; document.getElementById('nav-btns').style.display = 'flex';

  // Esconder chips de morador na tela inicial limpa
  const chipsCont = document.getElementById('chips-moradores');
  if (chipsCont) chipsCont.style.display = 'none';

  irParaModulo(0);
}

// ============================================================
// HELPERS PRÉ-CADASTRO (globais)
// ============================================================
function atualizarBtnPreCadastro() {
  const btn = document.getElementById('btn-abrir-precadastro');
  if (btn) btn.style.display = totalMoradores >= 1 ? 'block' : 'none';
  atualizarResumoPreCadastro();
}

function atualizarResumoPreCadastro() {
  const el = document.getElementById('resumo-precadastro');
  if (!el) return;
  const nomes = [];
  for (let i = 0; i < totalMoradores; i++) {
    const n = getVal(getMoradorScope(i), 'M4_nome');
    if (n) nomes.push((i === 0 ? '👑 ' : '👤 ') + n);
  }
  if (nomes.length > 0) {
    el.innerHTML = nomes.join('<br>');
    el.style.display = 'block';
  } else {
    el.style.display = 'none';
  }
}

// ============================================================
// PRÉ-CADASTRO DE MORADORES (MODAL)
// ============================================================
function abrirModalPreCadastro() {
  const cont = document.getElementById('modal-pc-campos');
  if (!cont) return;
  cont.innerHTML = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const wrap = document.createElement('div');
    const lbl = document.createElement('div');
    lbl.className = 'campo-label';
    lbl.textContent = i === 0 ? '👑 Responsável (Morador 1)' : '👤 Morador ' + (i + 1);
    const inp = document.createElement('input');
    inp.type = 'text';
    inp.placeholder = i === 0 ? 'Nome completo do responsável' : 'Nome completo do morador ' + (i + 1);
    inp.value = getVal(sc, 'M4_nome') || '';
    inp.dataset.idx = i;
    wrap.appendChild(lbl);
    wrap.appendChild(inp);
    cont.appendChild(wrap);
  }
  document.getElementById('modal-precadastro').classList.add('ativo');
}

function fecharModalPreCadastro() {
  document.getElementById('modal-precadastro').classList.remove('ativo');
}

function confirmarPreCadastro() {
  const cont = document.getElementById('modal-pc-campos');
  if (!cont) return;
  cont.querySelectorAll('input').forEach(inp => {
    const i = parseInt(inp.dataset.idx);
    const sc = getMoradorScope(i);
    setVal(sc, 'M4_nome', inp.value.trim());
    if (i === 0) responsavelNome = inp.value.trim() || 'o Responsável';
  });
  fecharModalPreCadastro();

  // Revelar os questionários individuais após confirmar o pré-cadastro
  const tabBar = document.getElementById('tab-bar-moradores');
  const morArea = document.getElementById('area-morador');
  const aviso = document.getElementById('aviso-precadastro-pendente');
  if (tabBar) tabBar.style.display = '';
  if (morArea) morArea.style.display = '';
  if (aviso) aviso.style.display = 'none';

  renderTabsMoradores();
  renderMoradorAtual();
  if (typeof atualizarResumoPreCadastro === 'function') atualizarResumoPreCadastro();
  if (typeof atualizarBtnPreCadastro === 'function') atualizarBtnPreCadastro();
}

// ============================================================
// OBSERVAÇÕES
// ============================================================
function abrirModalObs() {
  if (!dadosGlobais.observacoes) dadosGlobais.observacoes = { texto: '' };
  document.getElementById('obs-textarea').value = dadosGlobais.observacoes.texto;
  document.getElementById('modal-obs').classList.add('ativo');
}
function fecharModalObs() {
  document.getElementById('modal-obs').classList.remove('ativo');
}
function salvarObs() {
  if (!dadosGlobais.observacoes) dadosGlobais.observacoes = { texto: '' };
  dadosGlobais.observacoes.texto = document.getElementById('obs-textarea').value;
  salvarDados();
  fecharModalObs();
}

// ============================================================
// INICIALIZAÇÃO
// ============================================================
window.addEventListener('DOMContentLoaded', () => {
  carregarDados();
  irParaModulo(0);
});
</script>
