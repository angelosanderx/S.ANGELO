// NAVEGAÇÃO ENTRE MÓDULOS
// ============================================================
function irParaModulo(idx) {
  moduloAtual = idx; moradorAtual = 0;
  document.getElementById('tela-resumo').style.display = 'none'; document.getElementById('main').style.display = 'block'; document.getElementById('nav-btns').style.display = 'flex';
  const modBtns = document.querySelectorAll('.mod-btn'); modBtns.forEach((b,i) => b.classList.toggle('ativo', i === idx));
  MODULOS[idx].render();
  renderEtiquetasMoradores();
  atualizarProgresso(); window.scrollTo({top:0, behavior:'smooth'});
}

// Módulos que têm navegação por morador (índices no array MODULOS)
const MODULOS_POR_MORADOR = [1, 2, 3, 4, 5]; // Moradores, Educação, Trabalho, MEI, Rendimentos

function idadeMinimaPorModulo(mod) {
  if (mod === 2) return 5;   // Educação
  if (mod === 3) return 14;  // Trabalho
  if (mod === 4) return 14;  // MEI
  return 0;
}

function moradorElegivelNoModulo(idx, mod) {
  const sc = getMoradorScope(idx);
  const idade = parseInt(getVal(sc, 'M9_idade') || '0');
  return idade >= idadeMinimaPorModulo(mod);
}

function salvarMoradorModuloAtual() {
  if (moduloAtual === 1) return validarESalvarMorador();

  // Para os demais módulos por morador, apenas marca como concluído
  const scopeKey = ['', 'moradores', 'educacao', 'trabalho', 'mei', 'rendimentos'][moduloAtual];
  if (!scopeKey) return true;
  const arr = dadosGlobais[scopeKey];
  while (arr.length <= moradorAtual) arr.push({});
  arr[moradorAtual]['_concluido'] = true;
  salvarDados();
  return true;
}

function proximoMoradorElegivel(atual, mod) {
  for (let i = atual + 1; i < totalMoradores; i++) {
    if (moradorElegivelNoModulo(i, mod)) return i;
  }
  return -1;
}

function renderModuloMoradorAtual() {
  if (moduloAtual === 1) { renderTabsMoradores(); renderMoradorAtual(); }
  else if (moduloAtual === 2) { renderTabsEducacao(); renderEducacaoMorador(); }
  else if (moduloAtual === 3) { renderTabsTrabalho(); renderTrabalhoMorador(); }
  else if (moduloAtual === 4) { renderTabsMEI(); renderMEIMorador(document.getElementById('area-mei')); }
  else if (moduloAtual === 5) { renderTabsRendimentos(); renderRendimentosMorador(document.getElementById('area-rend')); }
  renderEtiquetasMoradores();
}

function navProximo() {
  if (MODULOS_POR_MORADOR.includes(moduloAtual)) {
    if (!salvarMoradorModuloAtual()) return;

    const proximo = proximoMoradorElegivel(moradorAtual, moduloAtual);
    if (proximo !== -1) {
      moradorAtual = proximo;
      renderModuloMoradorAtual();
      window.scrollTo({top: 0, behavior: 'smooth'});
      atualizarBotoes();
      return;
    }

    // Último morador do módulo — confirmação antes de avançar
    if (moduloAtual === 1) {
      const todosConcluidos = dadosGlobais.moradores.length >= totalMoradores &&
                              dadosGlobais.moradores.slice(0, totalMoradores).every(m => m.M_concluido);
      if (!todosConcluidos) {
        alert('Existem moradores ainda não concluídos. Finalize todos antes de continuar.');
        return;
      }
    }
    alert('✅ Módulo concluído para todos os moradores! Avançando para o próximo módulo.');
  }

  if (moduloAtual < MODULOS.length - 1) {
    irParaModulo(moduloAtual + 1);
  } else {
    finalizarQuestionario();
  }
  atualizarBotoes();
}

function navAnterior() {
  if (moduloAtual > 0) { irParaModulo(moduloAtual - 1); }
  atualizarBotoes();
}

function atualizarBotoes() {
  const prev = document.getElementById('btn-prev');
  const next = document.getElementById('btn-next');

  prev.classList.toggle('btn-disabled', moduloAtual === 0);

  if (MODULOS_POR_MORADOR.includes(moduloAtual)) {
    next.textContent = '✓ Salvar Morador';
    next.className = 'btn btn-verde';
    next.classList.remove('btn-disabled');
  } else if (moduloAtual === MODULOS.length - 1) {
    next.textContent = '✅ Finalizar';
    next.className = 'btn btn-verde';
    next.classList.remove('btn-disabled');
  } else {
    next.textContent = 'Próximo →';
    next.className = 'btn btn-prim';
    next.classList.remove('btn-disabled');
  }
}

function atualizarProgresso() {
  const pct = Math.round(((moduloAtual + 1) / MODULOS.length) * 100);
  document.getElementById('progress-bar').style.width = pct + '%';
  document.getElementById('progress-label').textContent = `Módulo ${moduloAtual+1} de ${MODULOS.length} – ${pct}% concluído`;
  atualizarBotoes();
}

