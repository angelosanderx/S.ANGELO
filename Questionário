function renderTrabalho() {
  const main = document.getElementById('main');
  main.innerHTML = '';

  const mh = document.createElement('div');
  mh.className = 'modulo-header';
  mh.innerHTML = `<div class="mod-icon">💼</div><div><h2>Módulo 4 – Trabalho</h2><p>Atividades laborais para moradores com 14 anos ou mais</p></div>`;
  main.appendChild(mh);

  const tabBar = document.createElement('div');
  tabBar.className = 'morador-tab-bar';
  tabBar.id = 'tab-bar-trab';
  main.appendChild(tabBar);

  const area = document.createElement('div');
  area.id = 'area-trab';
  main.appendChild(area);

  renderTabsTrabalho();
  renderTrabalhoMorador();
  renderEtiquetasMoradores();
}

function renderTabsTrabalho() {
  const bar = document.getElementById('tab-bar-trab');
  if (!bar) return;
  bar.innerHTML = '';
  for (let i = 0; i < totalMoradores; i++) {
    const sc = getMoradorScope(i);
    const idade = parseInt(getVal(sc,'M9_idade') || '0');
    if (idade < 14) continue;
    const nome = getVal(sc,'M4_nome') || ('Morador ' + (i+1));
    const btn = document.createElement('button');
    const concTrab = (dadosGlobais.trabalho[i] || {})['_concluido'];
    btn.className = 'morador-tab' + (i === moradorAtual ? ' ativo' : '') + (concTrab ? ' concluido' : '');
    btn.textContent = (nome.split(' ')[0] || ('Morador '+(i+1)));
    btn.addEventListener('click', () => {
      moradorAtual = i;
      renderTabsTrabalho();
      renderTrabalhoMorador();
      renderEtiquetasMoradores();
    });
    bar.appendChild(btn);
  }
  renderEtiquetasMoradores();
}

function renderTrabalhoMorador() {
  const area = document.getElementById('area-trab');
  if (!area) return;
