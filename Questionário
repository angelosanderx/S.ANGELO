function aplicarSaltosEducacao(scope, area) {
  if (!area) return;
  const v = (id) => id === 'ED0' ? getVal(dadosGlobais.habitacao, 'ED0') : getVal(scope, id);
  const vis = {};

  const allIds = [
    'E1','E2','E2A','E3A','E4A','E5A','E6','E6B','E6C','E6D','E7','E8','E9A',
    'E10','E10A','E11A','E12','E13','E14','E16','E17','E17A','E18','E19A',
    'E20B','E20C','E21A','E22C','E22D','E22E','E23A','E24A','E26','E26A',
    'E29','E29A','E30A','E32','E34A','E34B','E34C','E35'
  ];
  allIds.forEach(id => vis[id] = false);

  const modo = v('ED0');

  if (modo === '1') {
      vis.E1 = true;
      vis.E2 = true;

      if (v('E2') === '1') {
          vis.E2A = true;
          vis.E3A = true;

          const cAtual = v('E3A');
          if (cAtual !== '8' && cAtual !== '9' && cAtual !== '10') {
              vis.E6 = true;
          }
      } else if (v('E2') === '2') {
          vis.E8 = true;
          if (v('E8') === '1') {
              vis.E9A = true;
              vis.E12 = true;
              vis.E13 = true;
              vis.E14 = true;
          }
      }
      vis.E35 = true;

  } else if (modo === '2') {
      vis.E1 = true;
      vis.E2 = true;

      if (v('E2') === '1') {
          vis.E2A = true;
          vis.E3A = true;
          const cAtual = v('E3A');

          if (cAtual === '1' || cAtual === '2') { vis.E6 = true; vis.E26 = true; }
          else if (cAtual === '3') { vis.E6 = true; vis.E6C = true; vis.E6D = true; vis.E26 = true; }
          else if (cAtual === '4') { vis.E6 = true; vis.E6C = true; vis.E26 = true; }
          else if (cAtual === '5') {
              vis.E6 = true; vis.E6B = true; vis.E6C = true; vis.E6D = true; vis.E19A = true;
              if (v('E19A') === '1' || v('E19A') === '2') { vis.E20B = true; vis.E20C = true; vis.E26 = true; }
              else if (v('E19A') === '3' || v('E19A') === '4') { vis.E26 = true; }
          }
          else if (cAtual === '6') {
              vis.E6 = true; vis.E6B = true; vis.E6C = true; vis.E19A = true;
              if (v('E19A') === '1' || v('E19A') === '2') { vis.E20B = true; vis.E20C = true; vis.E26 = true; }
              else if (v('E19A') === '3' || v('E19A') === '4') { vis.E26 = true; }
          }
          else if (cAtual === '7') {
              vis.E4A = true; vis.E5A = true; vis.E6 = true; vis.E6B = true;
              if (v('E6B') === '1') { vis.E6C = true; vis.E7 = true; } else if (v('E6B') === '2') { vis.E7 = true; }
              if (v('E7') === '1') { vis.E10A = true; vis.E11A = true; vis.E13 = true; vis.E16 = true; vis.E17 = true; vis.E18 = true; vis.E21A = true; }
              else if (v('E7') === '2') { vis.E18 = true; vis.E21A = true; }
          }
          else if (['8','9','10'].includes(cAtual)) {
              vis.E6B = true; vis.E17A = true; vis.E18 = true; vis.E21A = true;
          }

          if (vis.E21A) {
              if (v('E21A') === '1' || v('E21A') === '2') { vis.E22C = true; vis.E22D = true; vis.E22E = true; vis.E23A = true; vis.E26 = true; }
              else if (v('E21A') === '3') { vis.E26 = true; }
          }

      } else if (v('E2') === '2') {
          vis.E8 = true;
          if (v('E8') === '1') {
              vis.E9A = true;
              const cAnt = v('E9A');

              if (cAnt === '1' || cAnt === '2') { vis.E17 = true; vis.E24A = true; vis.E26 = true; }
              else if (cAnt === '3') { vis.E14 = true; vis.E17 = true; vis.E24A = true; vis.E26 = true; }
              else if (cAnt === '4') { vis.E10 = true; vis.E12 = true; vis.E13 = true; vis.E14 = true; vis.E17 = true; vis.E24A = true; vis.E26 = true; }
              else if (cAnt === '5') { vis.E12 = true; vis.E13 = true; vis.E14 = true; vis.E17 = true; vis.E24A = true; vis.E26 = true; }
              else if (cAnt === '6' || cAnt === '7') { vis.E12 = true; vis.E13 = true; vis.E14 = true; vis.E17 = true; vis.E24A = true; vis.E26 = true; }
              else if (cAnt === '8') {
                  vis.E10A = true; vis.E11A = true; vis.E12 = true; vis.E13 = true; vis.E14 = true; vis.E17 = true; vis.E18 = true; vis.E19A = true;
                  if (v('E19A') === '1' || v('E19A') === '2') { vis.E20B = true; vis.E20C = true; vis.E29 = true; }
                  else if (v('E19A') === '3' || v('E19A') === '4') { vis.E29 = true; }
              }
              else if (['9','10','11'].includes(cAnt)) {
                  vis.E14 = true; vis.E16 = true; vis.E17 = true; vis.E17A = true; vis.E18 = true; vis.E21A = true;
                  if (v('E21A') === '1' || v('E21A') === '2') { vis.E22C = true; vis.E22D = true; vis.E22E = true; vis.E23A = true; vis.E26 = true; }
                  else if (v('E21A') === '3') { vis.E26 = true; }
              }
          } else if (v('E8') === '2') {
              vis.E26 = true;
          }
      }

      if (vis.E26) {
          if (v('E26') === '1') { vis.E26A = true; vis.E29 = true; }
          else if (v('E26') === '2') { vis.E29 = true; }
      }

      let vaiParaEvasaoOuFim = false;
      if (vis.E29) {
          if (v('E29') === '1') {
              vis.E29A = true; vis.E30A = true; vis.E32 = true;
              vaiParaEvasaoOuFim = true;
          }
          else if (v('E29') === '2') {
              vaiParaEvasaoOuFim = true;
          }
      }

      if (vaiParaEvasaoOuFim) {
          if (v('E2') === '2' && v('E8') === '1') {
              const fazAlgumCurso = (
                  v('E19A') === '1' || v('E19A') === '2' ||
                  v('E24A') === '1' ||
                  v('E26') === '1'
              );

              if (!fazAlgumCurso) {
                  vis.E34A = true;
                  vis.E34B = true;
                  vis.E34C = true;
              }
          }
      }

      vis.E35 = true;
  }

  allIds.forEach(id => {
      const el = area.querySelector('#q_' + id);
      if (el) mostrarOcultar(el, vis[id]);
  });
}
