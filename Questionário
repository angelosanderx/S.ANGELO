function calcularIdade(scope, dataNasc) {
  if (!dataNasc) return;
  const nasc = new Date(dataNasc);
  const ref = new Date();

  let idade = ref.getFullYear() - nasc.getFullYear();
  const m = ref.getMonth() - nasc.getMonth();
  if (m < 0 || (m === 0 && ref.getDate() < nasc.getDate())) idade--;
  const result = Math.max(0, idade);
  setVal(scope,'M9_idade', result);
  const inp = document.querySelector('[data-key="M9_idade"]');
  if (inp) inp.value = result;
  atualizarTextoIdadeBase(scope, result);
}

function atualizarTextoIdadeBase(scope, valor) {
  const hoje = new Date();
  const meses = ['janeiro', 'fevereiro', 'março', 'abril', 'maio', 'junho', 'julho', 'agosto', 'setembro', 'outubro', 'novembro', 'dezembro'];
  const mesAtual = meses[hoje.getMonth()];
  const anoAtual = hoje.getFullYear();

  const baseTxt = valor ? `${valor} anos em ${mesAtual} de ${anoAtual}` : '';
  setVal(scope, 'M9_base_str', baseTxt);
  const txtEl = document.getElementById('txt_M9_base');
  if (txtEl) txtEl.textContent = baseTxt;
}

